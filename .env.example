# ===== Luna Studio – Environment Variables =====

# URL webu (SEO metadata, OG, sitemap). Pro produkci nastavte skutečnou doménu.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google reCAPTCHA (volitelné – defaultně se používá honeypot u kontaktu).
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# E-mail pro notifikace z kontaktu (volitelné – výchozí je mock v API).
# CONTACT_EMAIL=hello@lunastudio.cz
