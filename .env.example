# ===== Kavárna Mletá & Měkká – Environment Variables =====

# URL webu (pro SEO metadata, OG, sitemap). UNSPECIFIED – nastavit pro produkci.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Token pro export rezervací do CSV (chráněný endpoint).
# UNSPECIFIED – nastavit vlastní token před deployem.
RESERVATIONS_EXPORT_TOKEN=change-me-before-deploy

# Google reCAPTCHA (volitelné – defaultně se používá honeypot).
# Pokud chcete zapnout reCAPTCHA, nastavte obě proměnné.
# NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
# RECAPTCHA_SECRET_KEY=

# Google Maps embed API key (volitelné, pro vlastní mapy).
# NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Kontaktní e-mail pro notifikace (unspecified – mock).
# CONTACT_EMAIL=ahoj@kavarnamleta.cz
